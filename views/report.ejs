<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank Statement Analyser</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous"
    >
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <link rel="stylesheet" href="/styles/main.css">

    
</head>

<body>

    <%- include('partials/header.ejs') %>


    <div class="container py-5">

         <div class="text-center mb-5">

           <h1 class="fw-bold">
            Financial Analysis Report
           </h1>

           <p class="text-muted">
            AI Powered Financial Dashboard
           </p>

        </div>

        <!-- Summary Cards -->

        <div class="row g-4 mb-5">

           <div class="col-md-3">

              <div class="card shadow p-4 bg-success text-white">

                <h5>Total Income</h5>

                <h2>
                    ₹ <%= income_vs_expense.total_income %>
                </h2>

            </div>

           </div>

        <div class="col-md-3">

            <div class="card shadow p-4 bg-danger text-white">

                <h5>Total Expense</h5>

                <h2>
                    ₹ <%= income_vs_expense.total_expense %>
                </h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow p-4 bg-primary text-white">

                <h5>Net Savings</h5>

                <h2>
                    ₹ <%= (
                        Number(income_vs_expense.total_income) -
                        Number(income_vs_expense.total_expense)
                    ).toFixed(2) %>
                </h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card shadow p-4 bg-dark text-white">

                <h5>Financial Health</h5>

                <h2>
                    <%= financial_health %>
                </h2>

            </div>

        </div>

    </div>

    <div class="row g-4 mb-5">

    <!-- AI Summary -->

    <div class="col-md-6">

        <div class="card shadow p-4 h-100">

            <h2>
                AI Financial Summary
            </h2>

            <pre><%= ai_summary %></pre>

        </div>

    </div>

    <!-- Expense Breakdown Chart -->

    <div class="col-md-6">

        <div class="card shadow p-4 h-100">

            <h2>
                Expense Breakdown Chart
            </h2>

            <div style="height: 350px;">

                <canvas id="expenseChart"></canvas>

            </div>

        </div>

    </div>

</div>

    <!-- Unusual Transactions -->

    <div class="card shadow p-4 mb-5 border border-danger">

        <h2 class="text-danger">
            Unusual Transactions
        </h2>

        <table class="table table-bordered table-hover">

            <thead class="table-danger">

                <tr>

                    <th>Date</th>
                    <th>Narration</th>
                    <th>Debit</th>

                </tr>

            </thead>

            <tbody>

            <% unusual_transactions.forEach((u)=>{ %>

                <tr>

                    <td>
                        <%= u.date %>
                    </td>

                    <td>
                        <%= u.narration %>
                    </td>

                    <td class="text-danger fw-bold">
                        ₹ <%= u.debit %>
                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

    <!-- Full Transactions -->

    <div class="card shadow p-4 mb-5">

        <h2>
            Full Transaction History
        </h2>

        <table class="table table-bordered table-striped table-hover">

            <thead class="table-dark">

                <tr>

                    <th>Date</th>
                    <th>Narration</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th>Balance</th>
                    <th>Category</th>

                </tr>

            </thead>

            <tbody>

            <% categorization.forEach((tx)=>{ %>

                <tr>

                    <td><%= tx.date %></td>

                    <td><%= tx.narration %></td>

                    <td class="text-danger">

                        <% if(tx.debit > 0){ %>

                            ₹ <%= tx.debit %>

                        <% } else { %>

                            -

                        <% } %>

                    </td>

                    <td class="text-success">

                        <% if(tx.credit > 0){ %>

                            ₹ <%= tx.credit %>

                        <% } else { %>

                            -

                        <% } %>

                    </td>

                    <td>
                        ₹ <%= tx.balance %>
                    </td>

                    <td>
                        <%= tx.category %>
                    </td>

                </tr>

            <% }) %>

            </tbody>

        </table>

    </div>

</div>






<script>
    
    const breakdown = <%- JSON.stringify(category_breakdown) %>;
    
    const labels = Object.keys(breakdown);
    
    const values = Object.values(breakdown);

    new Chart(document.getElementById("expenseChart"), {

        type: "pie",

        data: {
            
            labels: labels,
            
            datasets: [{
                
                data: values
                
            }]
        }
        
    });
    
</script>
<%- include('partials/footer.ejs') %>
</body>

</html>