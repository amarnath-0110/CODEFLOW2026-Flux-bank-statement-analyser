<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank Statement Analyser</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous"
    >
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/styles/main.css">
    <link rel="stylesheet" href="/styles/report.css">

    
</head>

<body>

    <%- include('partials/header.ejs') %>


    <div class="container py-5">

        <div class="text-center mb-5">
           <h1 class="report-title">
            Financial Analysis Report
           </h1>
           <p class="report-subtitle" >
            AI Powered Financial Dashboard
           </p>

        </div>


        <div class="row g-4 mb-5">
           <div class="col-md-3">
              <div class="card shadow-sm p-4 bg-success-subtle text-success-emphasis text-white summary-card">
                <h5>Total Income</h5>
                <h2>
                    ₹ <%= income_vs_expense.total_income %>
                </h2>
            </div>
           </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-4 bg-danger-subtle text-danger-emphasis text-white summary-card">
                <h5>Total Expense</h5>
                <h2>
                    ₹ <%= income_vs_expense.total_expense %>
                </h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-4 bg-primary-subtle text-primary-emphasis text-white summary-card">
                <h5>Net Savings</h5>
                <h2>
                    ₹ <%= (
                        Number(income_vs_expense.total_income) -
                        Number(income_vs_expense.total_expense)
                    ).toFixed(2) %>
                </h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm p-4 bg-dark text-white summary-card">
                <h5>Financial Health</h5>
                <h2>
                    <%= financial_health %>
                </h2>
            </div>
        </div>

    </div>

    <div class="row g-4 mb-5">
      <div class="col-md-6">
        <div class="card shadow-sm p-4">
            <h2>
                AI Financial Summary
            </h2>
            <div class="ai-summary">
                 <%- ai_summary.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br>')
                %>
            </div>
        </div>
      </div>


    <div class="col-md-6">
        <div class="card shadow-sm p-4">
            <h2>
                Expense Breakdown Chart
            </h2>
            <div style="height: 350px;">
                <div class="chart-container">
                    <canvas id="expenseChart"></canvas>
                </div>
            </div>
        </div>
    </div>

</div>

    <div class="card shadow-sm p-4 mb-5 border border-danger">
        <h2 class="text-danger">
            Unusual Transactions
        </h2>
        <table class="table table-bordered table-hover">
            <thead class="table-danger">
                <tr>
                    <th>Date</th>
                    <th>Narration</th>
                    <th>Debit</th>
                </tr>
            </thead>
            <tbody>
            <% unusual_transactions.forEach((u)=>{ %>
                <tr>
                    <td>
                        <%= u.date %>
                    </td>
                    <td>
                        <%= u.narration %>
                    </td>
                    <td class="text-danger fw-bold">
                        ₹ <%= u.debit %>
                    </td>
                </tr>
            <% }) %>
            </tbody>
        </table>
    </div>

    <div class="card shadow-sm p-4 mb-5">
        <h2>
            Full Transaction History
        </h2>
        <table class="table table-bordered table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Narration</th>
                    <th>Debit</th>
                    <th>Credit</th>
                    <th>Balance</th>
                    <th>Category</th>
                </tr>
            </thead>
            <tbody>
            <% categorization.forEach((tx)=>{ %>
                <tr>
                    <td><%= tx.date %></td>
                    <td><%= tx.narration %></td>
                    <td class="text-danger">
                        <% if(tx.debit > 0){ %>
                            ₹ <%= tx.debit %>
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                    <td class="text-success">
                        <% if(tx.credit > 0){ %>
                            ₹ <%= tx.credit %>
                        <% } else { %>
                            -
                        <% } %>
                    </td>
                    <td>
                        ₹ <%= tx.balance %>
                    </td>
                    <td>
                        <%= tx.category %>
                    </td>
                </tr>
            <% }) %>
            </tbody>
        </table>
    </div>
</div>

<script>
    const breakdown = JSON.parse('<%- JSON.stringify(category_breakdown) %>');
    const labels = Object.keys(breakdown);
    const values = Object.values(breakdown);
    new Chart(document.getElementById("expenseChart"), {
        type: "pie",
        data: {
            labels: labels,
            datasets: [{
                data: values
            }]
        }
    });
</script>

<%- include('partials/footer.ejs') %>

</body>

</html>